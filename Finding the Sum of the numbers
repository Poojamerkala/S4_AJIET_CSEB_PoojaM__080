class Main {
    public static void main(String[] args) {
        int d=0;
        int n=124;
        int a=n;
        int sum=0;
        while(n>0){
            d=n%10;
            sum+=d;
            n=n/10;
        }
        System.out.println("Number="+a);
        System.out.println("Sum of the numbers="+sum);
    }
}
